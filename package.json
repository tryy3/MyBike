{
  "name": "mybike",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "shared",
    "strava-webhook-proxy"
  ],
  "scripts": {
    "build:shared": "npm run -w shared build",
    "test": "vp run -r test",
    "verify": "npm run build:shared && vp check && npm test",
    "prepare": "vp config"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-rc.4"
  },
  "devDependencies": {
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "drizzle-orm": "1.0.0-rc.4",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.17.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
