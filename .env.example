# Auth (required for server)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# Optional
# DB_PATH=server/data/mybike.db
# PORT=3001

# Strava integration (optional)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
# STRAVA_SCOPES=read,activity:read_all,profile:read_all
#
# Strava login/sign-up uses better-auth at:
# http://localhost:3001/api/auth/callback/strava
# Register that callback domain/path in your Strava app settings.
