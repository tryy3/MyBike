# Auth (required for server)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# Database (local Turso Database file by default)
# DB_PATH=server/data/mybike.db
# PORT=3001
#
# Turso Cloud (remote-only). When BOTH are set, the server ignores DB_PATH and
# connects over the network via @tursodatabase/serverless.
# TURSO_DATABASE_URL=libsql://your-db-org.turso.io
# TURSO_AUTH_TOKEN=
#
# One-time import of an existing local file into Turso Cloud (CLI):
#   turso db create mybike --from-file ./server/data/mybike.db
# Then set TURSO_DATABASE_URL / TURSO_AUTH_TOKEN from `turso db show` / `turso db tokens create`.
#
# Alternatively, keep DB_PATH (or SQLITE_IMPORT_PATH) pointing at the old local file
# while using Turso Cloud — the server copies bike/domain data once on startup and
# records a marker so it never runs again.
# SQLITE_IMPORT_PATH=server/data/mybike.db

# Logging (optional)
# LOG_LEVEL=info          # trace | debug | info | warn | error | fatal | silent
# LOG_FILE_PATH=server/data/mybike.log   # server default; proxy default: strava-webhook-proxy/data/proxy.log
# LOG_TO_FILE=true
# LOG_REDACT=true         # set false to disable redaction (Authorization, tokens, etc. appear in logs)

# Strava integration (optional)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
# STRAVA_SCOPES=read,activity:read_all,profile:read_all
#
# Strava webhook proxy (optional — public relay for Tailscale/private MyBike)
# STRAVA_WEBHOOK_PROXY_PORT=3002
# STRAVA_WEBHOOK_PROXY_DB_PATH=strava-webhook-proxy/data/strava-webhook-proxy.db
# Prefer Turso Cloud for the proxy when BOTH are set (remote-only; ignores local path):
# STRAVA_WEBHOOK_PROXY_TURSO_DATABASE_URL=libsql://your-proxy-db-org.turso.io
# STRAVA_WEBHOOK_PROXY_TURSO_AUTH_TOKEN=
# STRAVA_WEBHOOK_PROXY_API_KEY=
# STRAVA_VERIFY_TOKEN=
# STRAVA_WEBHOOK_CALLBACK_URL=https://your-proxy.example.com/webhook/strava
# STRAVA_SUBSCRIPTION_ID=
#
# MyBike server pull from proxy (optional)
# STRAVA_WEBHOOK_PROXY_URL=https://your-proxy.example.com
# STRAVA_WEBHOOK_PROXY_API_KEY=
# STRAVA_SUBSCRIPTION_ID=
# STRAVA_WEBHOOK_POLL_INTERVAL_MS=60000
#
# Strava login/sign-up uses better-auth at:
# http://localhost:3001/api/auth/callback/strava
# Register that callback domain/path in your Strava app settings.
