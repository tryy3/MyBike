{
  "name": "mybike-strava-webhook-proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run -w shared build && npm run -w logging build && tsc",
    "start": "node dist/index.js",
    "test": "vp test",
    "subscribe": "tsx scripts/subscribe.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.4",
    "express": "^5.2.1",
    "logging": "^0.0.1",
    "shared": "^0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "1.0.0-rc.4",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^7.0.0",
    "vite-plus": "0.2.2"
  }
}
