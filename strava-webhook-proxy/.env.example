# Required on the proxy host
STRAVA_WEBHOOK_PROXY_API_KEY=
STRAVA_VERIFY_TOKEN=
# Set after running `npm run -w strava-webhook-proxy subscribe` (see README)
STRAVA_SUBSCRIPTION_ID=

# Local Turso Database file (default)
# STRAVA_WEBHOOK_PROXY_DB_PATH=/data/strava-webhook-proxy.db

# Turso Cloud (remote-only). When BOTH are set, the local DB path is ignored.
# STRAVA_WEBHOOK_PROXY_TURSO_DATABASE_URL=libsql://your-proxy-db-org.turso.io
# STRAVA_WEBHOOK_PROXY_TURSO_AUTH_TOKEN=
#
# One-time import:
#   turso db create mybike-proxy --from-file ./data/strava-webhook-proxy.db

# Only needed when running the subscribe script from a dev machine (not on the VPS)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_WEBHOOK_CALLBACK_URL=https://hooks.example.com/webhook/strava
