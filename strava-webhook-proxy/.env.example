# Required on the proxy host
STRAVA_WEBHOOK_PROXY_API_KEY=
STRAVA_VERIFY_TOKEN=
# Set after running `npm run -w strava-webhook-proxy subscribe` (see README)
STRAVA_SUBSCRIPTION_ID=

# Only needed when running the subscribe script from a dev machine (not on the VPS)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_WEBHOOK_CALLBACK_URL=https://hooks.example.com/webhook/strava
